{
  "name": "openclaw-topic-router",
  "version": "0.1.0",
  "description": "OpenClaw plugin: automatic topic-based session routing for private chats",
  "type": "module",
  "main": "./dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
